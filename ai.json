  "contribution": {
    "new_word": {
      "process": "Open GitHub issue using 'New Word Proposal' template. Title format: '[dūn/dūnma] <English equivalent>'. Fields: word type, proposed word with IPA, English meaning, component breakdown (if dūnma), justification, usage examples, references. Discuss in issue thread until consensus. Maintainer integrates approved proposals."
    },
    "grammar_rule": {
      "process": "Open GitHub issue using 'Grammar Rule Proposal' template. Title format: '[Grammar] <Short description>'. Fields: rule description, examples, justification, references. Discuss until consensus. Maintainer integrates."
    },
    "dialect": {
      "phase1": "Open GitHub issue using 'Dialect Proposal' template. Outline core principles, purpose, examples of changes. Community discussion. Maintainer approval required.",
      "phase2": "After approval, a permanent branch is created (e.g. dialect-high-vokrenfoma). Fork repo, create branch from dialect branch, submit PR to dialect branch (not main)."
    },
    "guidelines": [
      "Check for existing similar words/rules before proposing.",
      "All discussion must happen in issue thread before PR.",
      "Use provided templates for consistency.",
      "Commit messages link back to originating issue."
    ]
  },
  "word_formation_rules": {
    "dūnma_construction": "First dūn = type/category. Each subsequent dūn = added context/specificity. Final dūn = 'context', shown in parentheses in English translation.",
    "examples": [
      {"phrase": "nam + lok = namlok", "meaning": "eat + place = kitchen (eat-place)"},
      {"phrase": "nam + lok + at = namlokat", "meaning": "eat + place + commercial = eatery (eat-place-commercial)"},
      {"phrase": "ja + keb + em = jakebem", "meaning": "good + meet + person = hello (good-meeting-person)"}
    ],
    "pluralization": "Append 'ma' after any noun.",
    "number_system": {
      "pattern": "Multi-digit numbers concatenate digit/place-value dūn. e.g. rif+nūl = 20 (two-zero), tor+mōt = 5000 (thousand-five).",
      "scale_words": {"un": 1, "rif": 2, "sol": 3, "lit": 4, "mōt": 5, "zōl": 6, "nil": 7, "pōl": 8, "fes": 9, "nūl": 0, "unūl": 10, "s̄an": 100, "tor": 1000, "tortor": 1000000, "nar": 1000000000, "nartor": 1000000000000, "narnar": 1e18}
    }
  }
}
