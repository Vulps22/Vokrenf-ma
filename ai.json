{
  "meta": {
    "name": "Vokrenfōma",
    "type": "constructed_language",
    "description": "Official constructed language repository. Community-driven, open-source. Only words and rules in this repository are considered official Vokrenfōma.",
    "copyright": "© 2025 Vulps22",
    "license": "Free use for any purpose including creative and commercial. Modified versions may not be distributed under the Vokrenfōma name. All proposed changes must be submitted via the contribution process."
  },
  "grammar": {
    "word_order": "SVO (Subject-Verb-Object)",
    "word_types": {
      "dūn": "Base word. Single syllable. Fundamental building block.",
      "dūnma": "Compound word. Two or more dūn combined. First dūn establishes type, subsequent dūn add context. Last dūn called 'context', usually represented in English with parentheses, e.g. namlok = eat(place)."
    },
    "perspective": {
      "rule": "Third-person only. No direct equivalents for I/we/you. Use demonstratives and number markers instead.",
      "demonstratives": {"ik": "this", "oc̄": "that"},
      "number_markers": {"un": "one (singular)", "ma": "lot/group (plural)"},
      "pronouns": {
        "I": "ik un",
        "we": "ik ma",
        "you_singular": "oc̄ un",
        "you_plural": "oc̄ ma"
      }
    },
    "nouns": {
      "singular": "Noun alone is singular. e.g. namlok = kitchen.",
      "plural": "Add 'ma' after noun. e.g. namlok ma = kitchens.",
      "specific_number": "Add number word after noun. e.g. namlok rif = two kitchens.",
      "emphatic_singular": "Add 'un' after noun. e.g. namlok un = one single kitchen.",
      "possession": "Possessor phrase before noun. e.g. ik un namlok = my kitchen; em ma ret ma = the people's things."
    },
    "verbs": {
      "person_agreement": "None. Verbs do not change based on subject.",
      "tense": {
        "present_standard": "No marker. e.g. ik un kahn = I go.",
        "present_formal": "tō before verb. e.g. ik un tō kahn = I go (formally).",
        "past": "ta before verb. e.g. ik un ta kahn = I went.",
        "future": "ti before verb. e.g. ik un ti kahn = I will go."
      }
    },
    "polarity_preference": {
      "end_of_sentence": {
        "ná": "False / Bad. e.g. namlokat ná = The eatery is bad.",
        "ja": "True / Good. e.g. namlokat ja = The eatery is good."
      },
      "start_of_sentence": {
        "ná": "Don't want / Dislike. e.g. ná ik un kahn = I don't want to go.",
        "ja": "Want / Like. e.g. ja ik un kahn = I want to go."
      }
    },
    "questions": {
      "general": "Start sentence with ken. e.g. ken oc̄ un ta kahn? = Did you go?",
      "specific": {
        "kentan": "When?",
        "kenlok": "Where?",
        "kenem": "Who?",
        "kenret": "What?",
        "kenlū": "Why?",
        "kenfō": "How?",
        "example": "kenem ti kahn? = Who will go?"
      }
    },
    "numbers": {
      "cardinal_quantity": "Number word placed after noun. e.g. namlok rif = two kitchens. Also used to name spans of time.",
      "ordinal_order": "Number word placed before noun. e.g. sol nōksolnūl = the third month.",
      "compound_time_examples": {
        "nilnōk": "seven-day = week",
        "pahunnūl": "year-ten = decade"
      },
      "examples": {
        "pah unnūl": "Noun+Number. ten years (quantity).",
        "unnūl pah": "Number+Noun. the tenth year (ordinal).",
        "pahunnūl": "Noun+Number fused. decade (named span)."
      }
    }
  },
